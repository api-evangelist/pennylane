    },
    {
      "name": "Change Events",
      "item": [
        {
          "name": "Get customer invoice change events",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" } ],
            "url": {
              "raw": "{{baseUrl}}/customer_invoices/changes?start_date=2026-07-01T00:00:00Z",
              "host": [ "{{baseUrl}}" ],
              "path": [ "customer_invoices", "changes" ],
              "query": [ { "key": "start_date", "value": "2026-07-01T00:00:00Z" } ]
            }
          }
