          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"customer\": {\n    \"name\": \"ACME SAS\",\n    \"reg_no\": \"12345678900010\",\n    \"country_alpha2\": \"FR\",\n    \"emails\": [\"billing@acme.example\"]\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/company_customers", "host": [ "{{baseUrl}}" ], "path": [ "company_customers" ] }
          }
        },
        {
          "name": "List suppliers",
          "request": {
            "method": "GET",
